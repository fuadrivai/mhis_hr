<IfModule mod_mime.c>
  AddType application/javascript .js .mjs
  AddType application/wasm .wasm
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /live-attendance/

  # ✅ JANGAN rewrite file apapun yang ada
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # fallback ke index.html
  RewriteRule . /live-attendance/index.html [L]
</IfModule>